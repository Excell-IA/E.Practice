# Template delle variabili d'ambiente del backend E.Practice.
# Copia in `.env` (gitignored) e personalizza per il tuo sviluppo locale.
# In container / Render le stesse var arrivano dall'ambiente di deploy.

# --- Identità modulo ---
MODULE_NAME=e-practice
TENANT_ID=demo
ENVIRONMENT=dev          # dev | staging | production

# --- Storage ---
STORAGE_MODE=memory      # V0: memory | V1: sql | ework
DATABASE_URL=postgresql+asyncpg://ework:ework_dev@localhost:5432/ework
EWORK_TENANT_SLUG=excellia
SEED_PATH=../data/seed.json

# --- HTTP / CORS ---
# Lista JSON di origini. In production: dominio Vercel del frontend.
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- Auth (opzionale per deploy demo) ---
# Se valorizzati, attivano HTTP Basic Auth sul backend.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASS=

# --- Servizi E.Work ---
ECONTACTS_BASE_URL=http://127.0.0.1:8001
ECONTACTS_TIMEOUT_SECONDS=3

# --- Logging ---
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console       # console (dev, colorato) | json (production)

# --- Tokenizzazione client (services/tokenize.py) ---
# Sale per sha256 client_token. In V1+ verrà gestito dal vault.
TENANT_SALT=demo-salt
